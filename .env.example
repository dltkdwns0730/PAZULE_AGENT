# =========================================================================
# PAZULE Environment Configuration (.env.example)
# =========================================================================
# 이 파일은 환경 설정의 템플릿입니다. 
# 실제 사용 시에는 이 파일을 .env로 복사한 후 실제 값을 입력하세요.

# 1. API Keys
GEMINI_API_KEY=your_gemini_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# 2. Model Settings
# BLIP_MODEL_ID=Salesforce/blip-vqa-base
# SIGLIP2_MODEL_ID=google/siglip2-base-patch16-224
# QWEN_VL_MODEL_ID=qwen/qwen3-vl-8b-instruct

# 3. Decision Thresholds
# LOCATION_PASS_THRESHOLD=0.70
# ATMOSPHERE_PASS_THRESHOLD=0.62

# 4. Global Flags
PAZULE_ENV=production           # development | production | test
SKIP_METADATA_VALIDATION=false  # GPS validation switch
BYPASS_MODEL_VALIDATION=false   # Mock inference switch
