# =============================================================================
# PAZULE .env.example
# =============================================================================
# 목적:
# - 이 파일은 "데모 모드로 clone 후 실행"을 우선 지원하는 예시입니다.
# - 실제 실행 시에는 이 파일을 .env로 복사한 뒤 필요한 값만 수정합니다.
# - 실제 API key, service role key, DB password는 이 파일에 기록하지 않습니다.

# =============================================================================
# 1. 데모 모드 필수 설정
# =============================================================================
# PAZULE_ENV 선택지: development | test | production
# - development: 로컬 개발/데모 실행
# - test: 테스트 실행
# - production: 실제 서비스 운영
PAZULE_ENV=development

# DEMO_AUTH_ENABLED 선택지: true | false
# - true: Supabase 로그인 없이 데모 계정/관리자 화면 사용
# - false: 실제 Supabase JWT 인증 사용
DEMO_AUTH_ENABLED=true

# SKIP_METADATA_VALIDATION 선택지: true | false
# - true: 업로드 이미지의 EXIF/GPS 메타데이터 검증 우회
# - false: 실제 위치 기반 검증 수행
SKIP_METADATA_VALIDATION=true

# BYPASS_MODEL_VALIDATION 선택지: true | false
# - true: SigLIP/BLIP/Qwen 모델 검증을 우회하고 데모 판정 사용
# - false: 실제 모델 검증 라인 사용
BYPASS_MODEL_VALIDATION=true

# STORAGE_BACKEND 선택지: json | db
# - json: data/current_answer.json 등 로컬 JSON 파일 사용
# - db: DATABASE_URL 기반 DB 사용
STORAGE_BACKEND=json

# =============================================================================
# 2. 데모 미션 위치 설정
# =============================================================================
# 프론트엔드 지도/위치 안내용 공개 값입니다.
VITE_MISSION_SITE_LAT=37.711988
VITE_MISSION_SITE_LON=126.6867095
VITE_MISSION_SITE_RADIUS_METERS=300

# VITE_SKIP_GPS_VALIDATION 선택지: true | false
# - true: 브라우저 위치 권한을 요청하지 않음
# - false: 미션 시작/제출 시 브라우저 GPS 권한 요청
VITE_SKIP_GPS_VALIDATION=true

# 백엔드 위치 검증용 값입니다.
MISSION_SITE_LAT=37.711988
MISSION_SITE_LON=126.6867095
MISSION_SITE_RADIUS_METERS=300
MISSION_GPS_MAX_ACCURACY_METERS=100

# SKIP_GPS_VALIDATION 선택지: true | false
# - true: 백엔드 GPS 좌표 검증 우회
# - false: mission site 반경과 GPS 정확도 검증
SKIP_GPS_VALIDATION=true

# =============================================================================
# 3. 데모 판정/세션 기본값
# =============================================================================
# 데모 모드에서는 BYPASS_MODEL_VALIDATION=true가 우선이므로 아래 값은 운영 전환 시 주로 사용됩니다.
LOCATION_PASS_THRESHOLD=0.70
ATMOSPHERE_PASS_THRESHOLD=0.35
MISSION_SESSION_TTL_MINUTES=60
MISSION_MAX_SUBMISSIONS=3
API_TIMEOUT_SECONDS=60.0
API_MAX_RETRIES=2

# =============================================================================
# 4. 실제 Supabase 인증 사용 시 설정
# =============================================================================
# DEMO_AUTH_ENABLED=false로 전환할 때 필요합니다.
# SUPABASE_URL=https://PROJECT_REF.supabase.co
# SUPABASE_JWKS_URL=https://PROJECT_REF.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_JWT_AUDIENCE=authenticated
# SUPABASE_SERVICE_ROLE_KEY=

# 프론트엔드에 노출되는 공개 Supabase 값입니다.
# VITE_SUPABASE_URL=https://PROJECT_REF.supabase.co
# VITE_SUPABASE_PUBLISHABLE_KEY 선택지: sb_publishable_... | eyJ...
# VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# VITE_SUPABASE_ANON_KEY=eyJ...

# =============================================================================
# 5. 실제 AI/API Provider 사용 시 설정
# =============================================================================
# 데모 모드에서는 API key가 없어도 실행되도록 설계합니다.
# production에서 LLM 재시도 힌트 또는 Qwen 판정을 사용하려면 아래 값을 실제 key로 채웁니다.

# LLM 재시도 힌트/LLM 검증용입니다. 둘 중 하나 이상을 설정합니다.
# GEMINI_API_KEY=
# OPENAI_API_KEY=

# Qwen-VL 판정용 OpenRouter key입니다.
# OPENROUTER_API_KEY=

# LLM_MODEL_ID 선택 예시: gemini-2.5-flash | gpt-4o-mini
# LLM_MODEL_ID=gemini-2.5-flash

# QWEN_VL_MODEL_ID 선택 예시: qwen/qwen3-vl-8b-instruct
QWEN_VL_MODEL_ID=qwen/qwen3-vl-8b-instruct

# SigLIP 모델 ID입니다.
SIGLIP2_MODEL_ID=google/siglip2-base-patch16-224

# =============================================================================
# 6. 실제 모델 선택/앙상블 설정
# =============================================================================
# MODEL_SELECTION_* 선택지: siglip2 | blip | ensemble | qwen
MODEL_SELECTION_LOCATION=siglip2
MODEL_SELECTION_ATMOSPHERE=siglip2

# ENSEMBLE_MODELS_* 선택 예시: siglip2,blip | siglip2 | blip | siglip2,qwen
ENSEMBLE_MODELS_LOCATION=siglip2,blip
ENSEMBLE_MODELS_ATMOSPHERE=siglip2,blip

# Council 교차 검증 설정입니다.
# COUNCIL_ENABLED 선택지: true | false
COUNCIL_ENABLED=true
COUNCIL_BORDERLINE_MARGIN=0.08

# =============================================================================
# 7. DB / Supabase CLI / 배포 보조 설정
# =============================================================================
# STORAGE_BACKEND=db로 전환할 때 사용합니다.
# DATABASE_URL 선택 예시:
# - sqlite:///data/pazule.db
# - postgresql+psycopg://USER:PASSWORD@HOST:PORT/DB_NAME
# DATABASE_URL=sqlite:///data/pazule.db

# Supabase CLI 또는 마이그레이션 스크립트용입니다.
# SUPABASE_ACCESS_TOKEN=
# SUPABASE_PROJECT_REF=
# SUPABASE_DB_PASSWORD는 .env에 장기 저장하지 말고 현재 shell 세션에만 설정하는 것을 권장합니다.

# =============================================================================
# 8. 프론트엔드 추가 공개 설정
# =============================================================================
# VITE_* 값은 브라우저 번들에 노출됩니다. secret을 넣지 않습니다.
# VITE_API_URL=http://localhost:8000
# VITE_NAVER_MAP_CLIENT_ID=
